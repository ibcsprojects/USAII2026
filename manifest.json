{
  "manifest_version": 3,
  "name": "GreenPages",
  "version": "1.0.0",
  "description": "Catches wasteful print formatting in Google Docs before it hits paper.",
  "permissions": ["activeTab", "storage", "identity"],
  "host_permissions": ["https://docs.google.com/document/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GreenPages"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": [
        "flagStore.js",
        "docsApi.js",
        "textAnchor.js",
        "flagCard.js",
        "printIntercept.js",
        "overlay.js",
        "summarySidebar.js",
        "analysis.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
