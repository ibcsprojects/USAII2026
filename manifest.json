{
  "manifest_version": 3,
  "name": "GreenPage",
  "version": "1.0",
  "description": "Helping reduce print paper waste",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://docs.google.com/document/*"],
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}